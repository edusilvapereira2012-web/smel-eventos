{
  "name": "eventhub-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "turbo": "^2.0.4",
    "typescript": "^5.4.5",
    "prettier": "^3.2.5",
    "eslint": "^8.57.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "argon2",
      "prisma",
      "@prisma/client",
      "@prisma/engines"
    ]
  }
}
