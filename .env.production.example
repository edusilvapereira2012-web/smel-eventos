# Ambiente
NODE_ENV=production

# URL das aplicações (Proxy Nginx - Porta 3050 exposta e mapeada no NPM do VPS)
APP_URL=https://eventos.valterpcjria.com.br
API_URL=https://eventos.valterpcjria.com.br/api

# Banco de Dados (PostgreSQL)
# Use 'postgres' como host dentro da rede do Docker Compose
DATABASE_URL="postgresql://postgres:postgres123@postgres:5432/eventhub?schema=public"
POSTGRES_PASSWORD=postgres123

# Redis / Valkey
# Use 'redis' como host dentro da rede do Docker Compose
REDIS_URL="redis://redis:6379"

# S3 Local (MinIO)
# Use 'minio' como host dentro da rede do Docker Compose
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_secret_key_123
MINIO_BUCKET_EVENTS=events
MINIO_BUCKET_CERTIFICATES=certificates
MINIO_EXTERNAL_URL=https://eventos.valterpcjria.com.br/minio

# Autenticação (Altere estas chaves em produção!)
JWT_SECRET=super_secret_jwt_key_12345_production_only
JWT_REFRESH_SECRET=super_secret_refresh_jwt_key_12345_production_only

# SMTP (Envio de Emails - Substituir com dados reais de produção)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@valterpcjria.com.br
SMTP_PASS=sua_senha_ou_token_de_app
SMTP_FROM="SMEL - Plataforma de Eventos <no-reply@valterpcjria.com.br>"

# Chave de Criptografia LGPD (Deve ser uma chave forte de 32 bytes em produção!)
ENCRYPTION_KEY=prod_enc_key_32bytes_vps_smel_eventos_2026!

# Chave de Assinatura de QR Codes (Chave forte em produção)
QR_SECRET=prod_qr_secret_32bytes_vps_smel_eventos_2026!
